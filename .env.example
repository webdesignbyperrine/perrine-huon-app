# ============================================================
# Variables d'environnement — Perrine Huon App
# Copiez ce fichier en .env.local et renseignez vos vraies valeurs.
# Ne jamais committer .env.local dans git.
# ============================================================

# --- Supabase ---
# Disponibles dans : https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- OpenAI (génération de contenu et d'images IA) ---
# Disponible dans : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Brevo (envoi d'emails transactionnels) ---
# Disponible dans : https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID de la liste Brevo à laquelle ajouter les contacts du formulaire de devis
# (par défaut : 2)
BREVO_LIST_ID=2

# ============================================================
# --- Apple Wallet (Carte de visite digitale) ---
# ============================================================
# Prérequis : compte Apple Developer Program (99 $/an)
# https://developer.apple.com/account/
#
# 1. Créer un Pass Type ID dans "Certificates, Identifiers & Profiles"
# 2. Générer un certificat de signature (.p12) pour ce Pass Type ID
# 3. Encoder le .p12 en base64 : base64 -i certificate.p12 | pbcopy
# 4. Télécharger le certificat WWDR G4 : https://www.apple.com/certificateauthority/AppleWWDRCAG4.cer
#    Puis convertir en PEM : openssl x509 -inform DER -in AppleWWDRCAG4.cer -out wwdr.pem
#    Et copier le contenu PEM dans APPLE_WWDR_CERT_PEM (sur une ligne avec \n)

APPLE_TEAM_ID=PLACEHOLDER_APPLE_TEAM_ID
APPLE_PASS_TYPE_ID=pass.com.perrinehuon.businesscard
APPLE_CERT_P12_BASE64=PLACEHOLDER_BASE64_ENCODED_P12_CERTIFICATE
APPLE_CERT_P12_PASS=PLACEHOLDER_P12_PASSWORD
APPLE_WWDR_CERT_PEM=PLACEHOLDER_WWDR_CERT_PEM

# ============================================================
# --- Google Wallet (Carte de visite digitale) ---
# ============================================================
# Prérequis : compte Google Cloud + validation Issuer
# 1. Créer un projet sur https://console.cloud.google.com
# 2. Activer "Google Wallet API"
# 3. Demander un Issuer ID sur https://pay.google.com/business/console (gratuit, 2-3 jours de validation)
# 4. Créer un Service Account avec le rôle "Google Pay & Wallet Console — Développeur"
# 5. Générer une clé JSON pour le Service Account
#    Copier "client_email" dans GOOGLE_WALLET_SA_EMAIL
#    Copier "private_key" dans GOOGLE_WALLET_SA_KEY (remplacer les vrais sauts de ligne par \n)

GOOGLE_WALLET_ISSUER_ID=PLACEHOLDER_GOOGLE_ISSUER_ID
GOOGLE_WALLET_SA_EMAIL=PLACEHOLDER@PLACEHOLDER.iam.gserviceaccount.com
GOOGLE_WALLET_SA_KEY=PLACEHOLDER_PRIVATE_KEY_RSA
